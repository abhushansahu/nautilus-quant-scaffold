@startuml data-model
title trade_baby_trade — Lower-Level Data Model (entities passed between pipeline stages)

hide empty members
skinparam classAttributeIconSize 0

' ====================================================================
' Shared enums / value objects
' ====================================================================
enum AssetClass {
  SPOT
  OPTION
  FUTURE
  PERP
}

enum Venue {
  INTERACTIVE_BROKERS
  BINANCE
  DERIVE
  OTHER
}

enum Side {
  BUY
  SELL
}

enum ActorKind {
  HUMAN
  AUTOMATION
}

class InstrumentId <<value>> {
  +symbol: str
  +venue: Venue
  +asset_class: AssetClass
}

' ====================================================================
' 1. INGESTION — what the hourly job produces
' ====================================================================
class IngestionWindow <<entity>> {
  +window_id: UUID
  +opened_at: datetime
  +closed_at: datetime
  +interval: timedelta  ' = 1h
}

class MarketSnapshot <<entity>> {
  +snapshot_id: UUID
  +instrument: InstrumentId
  +ts: datetime
  +open: Decimal
  +high: Decimal
  +low: Decimal
  +close: Decimal
  +volume: Decimal
  +bid: Decimal
  +ask: Decimal
  +order_book: dict
}

class AltDataSignal <<entity>> {
  +signal_id: UUID
  +kind: str            ' "sentiment" | "onchain"
  +instrument: InstrumentId
  +ts: datetime
  +score: float         ' normalized -1..1
  +raw: dict
}

class IngestedDataset <<aggregate>> {
  +window: IngestionWindow
  +snapshots: List<MarketSnapshot>
  +alt_signals: List<AltDataSignal>
}

' ====================================================================
' 2. ANALYSIS — each strategy emits one signal per instrument
' ====================================================================
class StrategySignal <<entity>> {
  +signal_id: UUID
  +strategy_id: str       ' "A" | "B" | ... | "N"
  +window_id: UUID
  +instrument: InstrumentId
  +option: Side           ' the proposed move
  +certainty: float       ' 0..1  (the "certainty" field)
  +risk_pct: float        ' % of book this strategy wants to allocate
  +expected_return: float
  +rationale: dict        ' the open "{ ... }" payload
}

' ====================================================================
' 3. RESULTSET — TopN selection across strategies
' ====================================================================
class DiversificationPolicy <<value>> {
  +top_n: int
  +max_per_instrument: int
  +max_per_strategy: float
  +max_gross_risk_pct: float
}

class ResultSet <<aggregate>> {
  +result_id: UUID
  +window_id: UUID
  +policy: DiversificationPolicy
  +ranked: List<StrategySignal>   ' sorted by score
  +selected: List<StrategySignal> ' the TopN
  +score(s: StrategySignal): float
}

' ====================================================================
' 4. ACTION — decisions, risk, portfolio, orders
' ====================================================================
class TradeDecision <<entity>> {
  +decision_id: UUID
  +source_signal: StrategySignal
  +instrument: InstrumentId
  +side: Side
  +target_qty: Decimal
  +actor_kind: ActorKind
  +approved: bool
}

class RiskAssessment <<value>> {
  +decision_id: UUID
  +within_limits: bool
  +breached_rules: List<str>
  +max_allowed_qty: Decimal
}

class WalletBalance <<entity>> {
  +venue: Venue
  +currency: str
  +free: Decimal
  +locked: Decimal
}

class PortfolioState <<aggregate>> {
  +ts: datetime
  +positions: dict
  +balances: List<WalletBalance>
  +gross_exposure_pct: float
  +net_exposure_pct: float
}

class OrderTicket <<entity>> {
  +client_order_id: UUID
  +instrument: InstrumentId
  +side: Side
  +qty: Decimal
  +order_type: str
  +status: str   ' maps to Nautilus OrderStatus
}

' ====================================================================
' 5. LEARNING + JOURNAL (cross-cutting)
' ====================================================================
class LearningRecord <<entity>> {
  +record_id: UUID
  +decision_id: UUID
  +realized_pnl: Decimal
  +signal_certainty: float
  +was_correct: bool
  +features: dict
}

class JournalEntry <<entity>> {
  +entry_id: UUID
  +ts: datetime
  +stage: str    ' INGEST|ANALYZE|RESULT|ACT|LEARN
  +ref_id: UUID
  +level: str
  +payload: dict
}

' ====================================================================
' Relationships (data flow)
' ====================================================================
IngestedDataset *-- IngestionWindow
IngestedDataset *-- "*" MarketSnapshot
IngestedDataset *-- "*" AltDataSignal
MarketSnapshot --> InstrumentId
AltDataSignal --> InstrumentId

StrategySignal --> InstrumentId
StrategySignal ..> IngestedDataset : derived from

ResultSet *-- DiversificationPolicy
ResultSet o-- "*" StrategySignal

TradeDecision --> StrategySignal : source
TradeDecision ..> RiskAssessment : evaluated by
TradeDecision ..> PortfolioState : sized against
PortfolioState *-- "*" WalletBalance
TradeDecision --> OrderTicket : emits

LearningRecord ..> TradeDecision
LearningRecord ..> OrderTicket
JournalEntry ..> IngestionWindow
@enduml
