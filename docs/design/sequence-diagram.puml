@startuml sequence-diagram
title trade_baby_trade — Sequence Diagram (live 0DTE flow)

skinparam sequenceMessageAlign center
autonumber

participant "TradingNode" as TN
participant "DataEngine\n+ OptionChainManager" as DE
participant "SessionActor" as Sess
participant "RegimeActor" as Reg
participant "Strategy\n(0DTE)" as Strat
participant "GreeksCalculator" as GC
participant "RiskEngine" as RE
participant "ExecutionEngine" as EE
participant "Portfolio" as PF
participant "LearningModule" as Learn
participant "Journal" as Journal

== Node start — instrument load ==
TN -> DE : build_options_chain (IB) / load instruments
DE --> TN : OptionContract + OptionSpread InstrumentIds
TN -> Sess : on_start()
TN -> Reg : on_start()
TN -> Strat : on_start()

== Subscribe — event-driven data (not batch fetch) ==
Strat -> DE : subscribe_quote_ticks(underlying)
Strat -> DE : subscribe_option_chain(series_id,\nsnapshot_interval_ms=60_000)
note over Strat, DE
  WARM tier: chain snapshots for signal gen.
  HOT tier: quote ticks on underlying + open legs.
end note
Sess -> Strat : publish session_phase (MessageBus)
Reg -> Strat : publish regime_tag (MessageBus)

== Signal evaluation — on_option_chain ==
DE -> Strat : on_option_chain(OptionChainSlice)
Strat -> Strat : build TradeIntent\n(edge, liquidity, target InstrumentId)

alt edge gate fails
  Strat -> Journal : record(GATE, "edge rejected")
else liquidity gate fails
  Strat -> Journal : record(GATE, "liquidity rejected")
else regime gate fails
  Strat -> Journal : record(GATE, "regime rejected")
else session gate fails
  Strat -> Journal : record(GATE, "session blackout")
else all gates pass
  Strat -> GC : portfolio_greeks(spot_shock, vol_shock)
  GC --> Strat : PortfolioGreeks
  Strat -> Strat : RiskPolicy.check(projected greeks)
  alt greek policy fails
    Strat -> Journal : record(GATE, "greek limit breached")
  else greek policy pass
    Strat -> Strat : build OrderList\n(OptionSpread / IB BAG)
    Strat -> RE : submit_order_list(orders)
    RE -> RE : notional / rate / qty checks
    alt RiskEngine rejects
      RE --> Strat : denied
      Strat -> Journal : record(ACT, "RiskEngine denied")
    else RiskEngine accepts
      RE -> EE : route to venue
      EE --> Strat : OrderAccepted
      Strat -> Journal : record(ACT, order_id)
    end
  end
end

== Post-entry — continuous management ==
loop while InPosition
  DE -> Strat : on_quote_tick(underlying)
  DE -> Strat : on_option_greeks(open legs)
  alt delta band breach
    Strat -> Strat : hedge via contingent order
    Strat -> RE : submit_order(hedge)
  else TP / SL / time stop
    Strat -> RE : submit_order_list(flatten)
  else SessionActor flatten signal
    Sess -> Strat : flatten_signal
    Strat -> RE : submit_order_list(flatten)
  end
end

== Fill → learning ==
EE -> PF : OrderFilled
PF -> Strat : on_order_filled
EE -> Learn : OrderFilled event
Learn -> Learn : attribute PnL\n(theta, gamma, vega, slippage)
Learn -> Journal : record(LEARN, LearningRecord)
@enduml
