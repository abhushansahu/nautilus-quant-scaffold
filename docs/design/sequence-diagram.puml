@startuml sequence-diagram
title trade_baby_trade — Sequence Diagram (complete hourly flow)

skinparam sequenceMessageAlign center
autonumber

actor "Clock\n(hourly)" as Clock
participant "IngestionScheduler" as Sched
participant "IngestionService" as Ingest
participant "DataSource[*]\n(IB/Binance/Derive)" as Src
participant "AltDataSource[*]\n(sentiment/onchain)" as Alt
participant "AnalysisEngine" as Analyze
participant "StrategyExecutor\n(ProcessPool, GIL-free)" as Pool
participant "Strategy A..N\n(N worker procs)" as Strat
participant "ResultSelector\n(incremental reduce)" as Select
participant "ActionEngine" as Action
participant "RiskManager" as Risk
participant "PortfolioManager" as Port
participant "ActorClassifier" as Actor
participant "Executor" as Exec
participant "nautilus_trader\nExecutionEngine" as NT
participant "LearningModule" as Learn
participant "Journal" as Journal

== Ingestion (every 1h) ==
Clock -> Sched : on_timer()
Sched -> Ingest : collect(window)
Ingest -> Src : fetch(window)
Src --> Ingest : List<MarketSnapshot>
Ingest -> Alt : fetch(window)
Alt --> Ingest : List<AltDataSignal>
Ingest --> Sched : IngestedDataset
Sched -> Journal : record(INGEST, window_id)

== Analysis + ResultSet (parallel fan-out / fan-in) ==
Sched -> Analyze : analyze(dataset)
note over Analyze, Pool
  Strategies are independent + CPU-bound →
  scatter across N workers. Dataset is
  read-only → shared (fork / shared-memory),
  not re-pickled per task.
end note
Analyze -> Pool : map(strategies, dataset) -> futures[]

par Strategy A  (worker proc 1)
  Pool -> Strat : evaluate(dataset)
  Strat --> Pool : signals_A
  Pool --> Select : as_completed: offer(signals_A)
  note right of Select : fold into running\nheap (overlaps compute)
else Strategy B  (worker proc 2)
  Pool -> Strat : evaluate(dataset)
  Strat --> Pool : signals_B
  Pool --> Select : as_completed: offer(signals_B)
else Strategy N  (worker proc k)
  Pool -> Strat : evaluate(dataset)
  Strat --> Pool : signals_N
  Pool --> Select : as_completed: offer(signals_N)
end

== Barrier: join (wait ALL_COMPLETED) ==
Analyze -> Pool : wait(timeout) — ALL_COMPLETED
note over Pool, Select
  Laggards past timeout are cancelled +
  journaled; selection proceeds degraded.
end note
Analyze -> Select : finalize()
Select -> Select : apply DiversificationPolicy,\npick TopN, deterministic sort
Select --> Sched : ResultSet{selected: TopN}
Select -> Journal : record(RESULT, result_id)

== Action (risk + portfolio + actor) ==
Sched -> Action : decide(resultSet)
loop each selected signal
  Action -> Port : state() / size(signal, balance)
  Port --> Action : PortfolioState + target_qty
  Action -> Risk : assess(decision, portfolio)
  Risk --> Action : RiskAssessment
  alt within limits
    Action -> Actor : classify(decision)
    Actor --> Action : ActorKind
    alt actor = AUTOMATION
      Action -> Exec : submit(ticket)
      Exec -> NT : submit_order(order)
      NT --> Exec : OrderStatus
    else actor = HUMAN
      Action -> Journal : record(ACT, "awaiting human approval")
      note right of Action : blocks until manual approve/decline
    end
  else breached limits
    Action -> Journal : record(ACT, "rejected: " + rules)
  end
end

== Learning (feedback) ==
NT --> Learn : OrderFilled / PositionChanged
Learn -> Learn : realized PnL vs certainty
Learn -> Learn : update_models()
Learn -> Journal : record(LEARN, LearningRecord)
Learn --> Sched : cycle complete
@enduml
