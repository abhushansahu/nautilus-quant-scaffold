@startuml concurrency-activity
title trade_baby_trade — Concurrency Model (live NT loop + offline research)

skinparam conditionStyle inside

|Live path — TradingNode|
start
:TradingNode.run() — single-threaded event loop;
note right
  Strategies and Actors are concurrent
  components on the NT MessageBus.
  No parallel ingestion pipeline.
end note

:DataEngine delivers events;
fork
  :SessionActor publishes session_phase;
fork again
  :RegimeActor publishes regime_tag;
fork again
  :Strategy.on_option_chain(slice);
  :evaluate layered gates;
  if (all gates pass?) then (yes)
    :GreeksCalculator.portfolio_greeks();
    :RiskPolicy check;
    if (policy pass?) then (yes)
      :submit_order_list → RiskEngine → ExecutionEngine;
    else (no)
      :journal reject;
    endif
  else (no)
    :journal skip;
  endif
fork again
  :Strategy.on_quote_tick / on_option_greeks;
  :post-entry hedge / flatten;
end fork

if (N strategies compete for capital?) then (yes)
  :SelectorActor join barrier;
  :apply DiversificationPolicy TopN;
  :deterministic sort;
else (no)
  :single Strategy — no selector;
endif

:LearningModule.observe(fill);
:Journal record;
stop

|Offline research — optional, never on order path|
start
:Load NT catalog snapshots;
note right
  ProcessPool map-reduce for heavy
  factor research, walk-forward calibration,
  strategy retirement analysis.
end note

:ProcessPoolExecutor.map(research_fn, snapshots);
fork
  partition "worker 1" {
    :factor analysis A;
  }
fork again
  partition "worker 2" {
    :factor analysis B;
  }
end fork

:aggregate results offline;
:feed back to Strategy config / RiskPolicy;
note right
  Results update config only —
  never block or drive the live event loop.
end note
stop
@enduml
