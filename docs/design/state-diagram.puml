@startuml state-diagram
title trade_baby_trade — State Diagram (per-strategy lifecycle + SessionActor)

[*] --> Flat

state Flat {
  Flat : no open position
  Flat : reject new entries if SessionActor blackout
}

Flat --> Evaluating : on_option_chain\nor on_quote_tick

state Evaluating {
  Evaluating : layered gates:\nedge, liquidity, regime,\nsession, greek, ops
  Evaluating : build TradeIntent +\ntarget OptionSpread InstrumentId
}

Evaluating --> Flat : any gate fails\n(journal reason)
Evaluating --> PendingEntry : submit_order_list

state PendingEntry {
  PendingEntry : awaiting RiskEngine +\nvenue acceptance
}

PendingEntry --> Flat : rejected or cancelled
PendingEntry --> InPosition : fill confirmed

state InPosition {
  InPosition : monitor on_quote_tick\n+ on_option_greeks
  InPosition : brackets / OrderEmulator active
}

InPosition --> Exiting : TP / SL / hedge trigger\n/ time stop
InPosition --> Flat : SessionActor flatten signal\n(T-30m blackout)

state Exiting {
  Exiting : submit flatten OrderList
  Exiting : wait for flat confirmation
}

Exiting --> Flat : flat confirmed

Flat --> [*] : TradingNode stop

' SessionActor interaction (cross-cutting)
state "SessionActor" as SA {
  state "Normal" as SAN
  state "Blackout" as SAB
  SAN : new entries allowed
  SAB : T-30m to close\nnew entries blocked
  SAN --> SAB : minutes_to_expiry <= 30
  SAB --> SAN : session reset
}

note right of Flat
  During blackout: Flat rejects entries;
  InPosition may still manage/flatten.
end note

note right of Evaluating
  No global batch cycle.
  Each Strategy owns its own state machine.
  Default = no trade until all gates pass.
end note

note bottom of InPosition
  Post-entry: delta band breach -> hedge;
  time stop -> flatten.
  Journal on every transition.
end note
@enduml
