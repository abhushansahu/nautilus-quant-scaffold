@startuml class-diagram
title trade_baby_trade — Class Diagram (NT-first extension layer)

hide empty members
skinparam classAttributeIconSize 0

' ====================================================================
' NautilusTrader engine boundary (we DO NOT reimplement these)
' ====================================================================
package "nautilus_trader (engine)" <<Frame>> {
  class TradingNode
  class DataEngine
  class GreeksCalculator
  class RiskEngine
  class ExecutionEngine
  class Portfolio
  class OrderEmulator
  class OptionChainManager
  class "Strategy (nt)" as NTStrategy
  class "Actor (nt)" as NTActor
}

' ====================================================================
' Custom Actors — cross-cutting context on MessageBus
' ====================================================================
class SessionActor {
  +blackout_windows: List<TimeWindow>
  +minutes_to_expiry(): int
  +session_phase(): str
  +allows_entry(): bool
  +flatten_signal(): bool
}
note right of SessionActor
  Publishes session phase and
  blackout (e.g. T-30m to close).
  Strategies reject new entries;
  InPosition strategies may flatten.
end note

class RegimeActor {
  +regime_tag(): str
  +update(context): void
}
note right of RegimeActor
  Rule-based chop / trend /
  pin_risk tags for gate input.
end note

class IngestionPlannerActor {
  +budget: IngestionBudget
  +plan_subscriptions(): List<SubscriptionSpec>
}
note right of IngestionPlannerActor
  Optional — cost-aware subscription
  planning when API budget is a constraint.
end note

' ====================================================================
' Custom Strategies — signal logic, gates, entry/exit/hedge
' ====================================================================
abstract class Strategy {
  +strategy_id: str
  +risk_policy: RiskPolicy
  +on_start(): void
  +on_option_chain(slice): void
  +on_quote_tick(tick): void
  +on_option_greeks(greeks): void
  +evaluate_gates(intent): bool
  +submit_order_list(orders): void
}
class StrategyA
class StrategyB
class StrategyN

note bottom of Strategy
  Inherits NT Strategy (which inherits Actor).
  .greeks -> GreeksCalculator.
  Owns per-strategy lifecycle state machine.
end note

' ====================================================================
' Multi-strategy selection (when N > 1 compete for capital)
' ====================================================================
class SelectorActor {
  +policy: DiversificationPolicy
  +collect(intent: TradeIntent): void
  +finalize(): List<TradeIntent>
}
note right of SelectorActor
  Join barrier on MessageBus when
  N strategies compete for shared capital.
  Applies DiversificationPolicy TopN.
end note

class DiversificationPolicy {
  +top_n: int
  +max_per_instrument: int
  +max_per_strategy: float
  +max_gross_risk_pct: float
}

' ====================================================================
' Human vs automation routing
' ====================================================================
class ActorClassifier {
  +classify(intent: TradeIntent): ActorKind
}
note bottom of ActorClassifier
  Routes small/auto-safe trades to
  AUTOMATION; large/risky to HUMAN.
end note

interface ApprovalHandler {
  +handle(intent: TradeIntent): void
}
class HumanApprovalHandler
class AutomationHandler

' ====================================================================
' Learning + Journal (cross-cutting)
' ====================================================================
class LearningModule {
  +observe(fill: OrderFilled): LearningRecord
  +calibrate(): void
}
class Journal {
  +record(stage, ref_id, payload): JournalEntry
}

' ====================================================================
' Inheritance
' ====================================================================
NTActor <|-- SessionActor
NTActor <|-- RegimeActor
NTActor <|-- IngestionPlannerActor
NTActor <|-- SelectorActor
NTStrategy <|-- Strategy
Strategy <|-- StrategyA
Strategy <|-- StrategyB
Strategy <|-- StrategyN
ApprovalHandler <|.. HumanApprovalHandler
ApprovalHandler <|.. AutomationHandler

' ====================================================================
' Composition / collaboration
' ====================================================================
TradingNode *-- DataEngine
TradingNode *-- GreeksCalculator
TradingNode *-- RiskEngine
TradingNode *-- ExecutionEngine
TradingNode *-- Portfolio
TradingNode *-- OrderEmulator
TradingNode o-- OptionChainManager

TradingNode o-- SessionActor
TradingNode o-- RegimeActor
TradingNode o-- IngestionPlannerActor
TradingNode o-- "*" Strategy
TradingNode o-- SelectorActor
TradingNode o-- LearningModule
TradingNode o-- Journal

SelectorActor *-- DiversificationPolicy
Strategy --> RegimeActor : subscribe regime_tag
Strategy --> SessionActor : subscribe session phase
Strategy --> GreeksCalculator : portfolio_greeks()
Strategy --> RiskEngine : submit_order_list()
Strategy --> ExecutionEngine : via RiskEngine
Strategy ..> SelectorActor : publish TradeIntent
Strategy ..> ActorClassifier : route large trades
HumanApprovalHandler --> ExecutionEngine
AutomationHandler --> ExecutionEngine

IngestionPlannerActor ..> DataEngine : subscription plan

LearningModule ..> Journal
Strategy ..> Journal
SelectorActor ..> Journal
@enduml
