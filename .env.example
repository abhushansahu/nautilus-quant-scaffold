# Copy to .env and fill in values. NEVER commit .env.
# All secrets are read from the environment at runtime; configs only reference these names.

# --- Environment selection ---
# One of: backtest | paper | live (defaults to backtest)
TRADE_ENV=backtest

# --- Binance (live/paper trading) ---
# Used by config/paper.yaml and config/live.yaml. Paper trading should use testnet keys.
BINANCE_API_KEY=
BINANCE_API_SECRET=
# true = use Binance testnet (recommended for paper), false = production endpoints
BINANCE_TESTNET=true

# --- Databento (historical market data ingestion) ---
# Used by src/data_pipeline/ingestion/databento.py
DATABENTO_API_KEY=
